generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  password       String
  role           UserRole
  createdAt      DateTime        @default(now())
  brandProfile   BrandProfile?
  creatorProfile CreatorProfile?

  @@index([email])
}

model BrandProfile {
  id             Int                @id @default(autoincrement())
  userId         Int                @unique
  name           String
  description    String?
  industry       IndustryCategory   @default(OTHER)
  websiteUrl     String?
  contactEmail   String?
  apiKey         String?            @unique
  createdAt      DateTime           @default(now())
  updatedAt      DateTime?          @updatedAt
  user           User               @relation(fields: [userId], references: [id])
  subscription   BrandSubscription?
  campaigns      Campaign[]
  paymentRecords PaymentRecord[]
  products       Product[]
}

model CreatorProfile {
  id        Int              @id @default(autoincrement())
  userId    Int              @unique
  name      String
  bio       String?
  niche     CreatorNiche
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  campaigns CampaignMember[]
  user      User             @relation(fields: [userId], references: [id])
}

model Product {
  id               Int               @id @default(autoincrement())
  brandId          Int
  name             String
  basePrice        Float
  skuId            String
  productUrl       String
  currency         Currency          @default(INR)
  status           ProductStatus     @default(AVAILABLE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  campaignProducts CampaignProduct[]
  brand            BrandProfile      @relation(fields: [brandId], references: [id])

  @@unique([brandId, skuId])
}

model Campaign {
  id                Int               @id @default(autoincrement())
  brandId           Int
  name              String
  status            CampaignStatus    @default(DRAFT)
  redirectUrl       String
  currency          Currency          @default(INR)
  payoutModel       PayoutModel       @default(BOTH)
  cpsCommissionType CommissionType
  cpsValue          Float
  cpcValue          Float?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  brand             BrandProfile      @relation(fields: [brandId], references: [id])
  invites           CampaignInvite[]
  members           CampaignMember[]
  products          CampaignProduct[]
}

model CampaignProduct {
  id         Int         @id @default(autoincrement())
  campaignId Int
  productId  Int
  campaign   Campaign    @relation(fields: [campaignId], references: [id])
  product    Product     @relation(fields: [productId], references: [id])
  sales      SaleEvent[]

  @@unique([campaignId, productId])
}

model CampaignInvite {
  id         Int          @id @default(autoincrement())
  campaignId Int
  email      String
  status     InviteStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  campaign   Campaign     @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, email])
}

model CampaignMember {
  id            Int            @id @default(autoincrement())
  campaignId    Int
  creatorId     Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  campaign      Campaign       @relation(fields: [campaignId], references: [id])
  creator       CreatorProfile @relation(fields: [creatorId], references: [id])
  clicks        ClickEvent[]
  referralCodes ReferralCode[]
  sales         SaleEvent[]

  @@unique([campaignId, creatorId])
}

model ReferralCode {
  id        Int            @id @default(autoincrement())
  memberId  Int
  platform  PlatformType
  code      String         @unique
  createdAt DateTime       @default(now())
  member    CampaignMember @relation(fields: [memberId], references: [id])

  @@unique([memberId, platform])
}

model SaleEvent {
  id                Int             @id @default(autoincrement())
  salePrice         Float
  currency          Currency        @default(INR)
  memberId          Int
  campaignProductId Int
  platform          PlatformType
  purchasedAt       DateTime        @default(now())
  campaignProduct   CampaignProduct @relation(fields: [campaignProductId], references: [id])
  member            CampaignMember  @relation(fields: [memberId], references: [id])
}

model ClickEvent {
  id       Int            @id @default(autoincrement())
  memberId Int
  platform PlatformType
  count    Int            @default(0)
  date     DateTime
  member   CampaignMember @relation(fields: [memberId], references: [id])

  @@unique([memberId, platform, date])
}

model BrandSubscription {
  id            Int          @id @default(autoincrement())
  brandId       Int          @unique
  plan          Plan         @default(BRAND_STARTER)
  startedAt     DateTime
  expiresAt     DateTime
  usedFreeTrial Boolean      @default(false)
  brand         BrandProfile @relation(fields: [brandId], references: [id])

  @@index([brandId])
}

model PaymentRecord {
  id                Int             @id @default(autoincrement())
  brandId           Int
  amount            Int
  currency          Currency        @default(INR)
  provider          PaymentProvider @default(RAZORPAY)
  providerPaymentId String
  paidAt            DateTime        @default(now())
  brand             BrandProfile    @relation(fields: [brandId], references: [id])
}

enum UserRole {
  BRAND
  CREATOR
  ADMIN
}

enum IndustryCategory {
  TECHNOLOGY
  CONSUMER_GOODS
  FOOD_AND_HEALTH
  ENTERTAINMENT
  TRAVEL_AND_HOSPITALITY
  FINANCE
  AUTOMOTIVE
  EDUCATION
  REAL_ESTATE
  PARENTING
  OTHER
}

enum CreatorNiche {
  FASHION
  BEAUTY
  TECH
  GAMING
  FITNESS
  LIFESTYLE
  FOOD
  TRAVEL
  EDUCATION
  OTHER
}

enum PlatformType {
  INSTAGRAM
  YOUTUBE
  X
  LINKEDIN
  FACEBOOK
  WHATSAPP
  TELEGRAM
  WEBSITE
}

enum Currency {
  INR
}

enum ProductStatus {
  AVAILABLE
  UNAVAILABLE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum InviteStatus {
  PENDING
  ACCEPTED
}

enum PayoutModel {
  CPS
  CPC
  BOTH
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum Plan {
  BRAND_GROWTH
  BRAND_STARTER
}

enum PaymentProvider {
  RAZORPAY
}
